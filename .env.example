# PyroCMS Pro 2.x — environment configuration
#
# Copy this file to `.env` (gitignored) and edit. The real `.env` is loaded
# by system/cms/bootstrap/env.php from the front controller (index.php).
#
# Real environment variables always win over .env values, so on staging /
# production you can either keep a server-local .env or set the variables
# via FPM/Apache SetEnv / docker --env / shell export.
#
# Anything left blank or absent falls back to the hardcoded defaults in the
# corresponding config file, so the site still boots without an .env.

# ---------------------------------------------------------------------------
# Application environment
# ---------------------------------------------------------------------------
# Drives index.php's switch-on-environment block. Valid values: development,
# staging, production. (The PYRO_DEVELOPMENT / PYRO_STAGING / PYRO_PRODUCTION
# constants are defined in index.php.)
PYRO_ENV=development

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Read by system/cms/config/database.php. Each missing key falls back to the
# hardcoded default in that file.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=pyrocmspro2ng

# `mysqli` (default) or `mysql` / `postgre` / `mssql`. Leave as mysqli unless
# you really know you need something else.
DB_DRIVER=mysqli

# Per-site table prefix. Leave empty unless you've configured multi-site.
DB_PREFIX=

# Connection charset / collation. utf8mb4 is the modern default; older
# installs may still be on utf8.
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ---------------------------------------------------------------------------
# Debugging (development env only — production should leave these unset)
# ---------------------------------------------------------------------------
# Show PHP errors in the response body. Truthy values: 1, true, on, yes.
APP_DISPLAY_ERRORS=true

# Log PHP errors via php's error_log() to a file. Path is absolute or relative
# to the project root. Leave blank to use the runtime default.
APP_ERROR_LOG=system/cms/logs/php-fatals.log

# Bitmask passed to error_reporting(). Common values:
#   E_ALL                (everything; noisy on PHP 8 with deprecated PyroCMS code)
#   E_ALL ^ E_DEPRECATED (everything except deprecation notices — recommended)
APP_ERROR_REPORTING=E_ALL ^ E_DEPRECATED
