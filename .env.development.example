# =============================================================================
# Development `.env` template
# =============================================================================
#
# Copy to `.env` (gitignored) and edit for your local box:
#
#     cp .env.development.example .env
#
# Most keys below ship with sensible defaults for a local Herd/Valet/MAMP-style
# install against MySQL 8 or 5.7, so you can often run unmodified.
#
# See system/cms/bootstrap/env.php for loader semantics (real env vars always
# win over .env, so this is purely your local override surface).

# -----------------------------------------------------------------------------
# Application environment
# -----------------------------------------------------------------------------
# development / staging / production. In development: errors visible, file
# logging enabled, stricter debug behaviour.
PYRO_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=pyrocmspro2ng

DB_DRIVER=mysqli
DB_PREFIX=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# -----------------------------------------------------------------------------
# Debug flag
# -----------------------------------------------------------------------------
# Auto-derived from PYRO_ENV — ON in development, OFF elsewhere. Only set this
# explicitly if you want the non-default: e.g. APP_DEBUG=false locally when
# reproducing a prod-only symptom.
#APP_DEBUG=true

# -----------------------------------------------------------------------------
# Error log path
# -----------------------------------------------------------------------------
# Project-relative path. PyroCMS's own log ignores E_DEPRECATED; this file
# catches the fatals PHP's handler would otherwise drop on the floor.
APP_ERROR_LOG=system/cms/logs/php-fatals.log

# -----------------------------------------------------------------------------
# Encryption key
# -----------------------------------------------------------------------------
# Used by CI's Encryption + Session classes. Generate one with:
#   php -r "echo bin2hex(random_bytes(32));"
# Rotating invalidates existing encrypted cookies/sessions and any DB columns
# encrypted via $this->encrypt->encode() — users will need to log in again.
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Member-protected folder gate
# -----------------------------------------------------------------------------
# Comma-separated folder names whose files require an authenticated member.
# Must match File Manager folder names exactly (case-sensitive).
PROTECTED_FOLDERS=safe,member,medlem_seminbockar,medlem_video,medlem_dokument,medlem_dokument_2022,medlem_bilder,medlem_2019,medlem_2023,medlem_2024,medlem_2025,medlem_2026

# -----------------------------------------------------------------------------
# SMS alerting recipients
# -----------------------------------------------------------------------------
# Comma-separated <name>:<phone> pairs.
# Example: SMS_REGISTERED=Alice:+46701234567,Bob:+46707654321
SMS_REGISTERED=

# -----------------------------------------------------------------------------
# Multi-site default fallback
# -----------------------------------------------------------------------------
# core_sites.ref used when the incoming hostname matches neither a site's
# primary domain nor a row in core_domains. Leave empty to keep the legacy
# hardcoded 'default' stub (which resolves to uploads/default + addons/default
# and will be broken if no default site actually exists).
DEFAULT_SITE=bockavel

# -----------------------------------------------------------------------------
# Mail delivery
# -----------------------------------------------------------------------------
# Master on/off switch. When false, templates/events.php::send_email short-
# circuits — useful locally to suppress registration / reset-password mails.
MAIL_ENABLED=false

# Each of these empty keys falls through to the matching row in Settings (admin
# → Settings → Email). Populate to bypass the DB for the current environment.
#MAIL_PROTOCOL=smtp
#MAIL_SMTP_HOST=
#MAIL_SMTP_PORT=587
#MAIL_SMTP_USER=
#MAIL_SMTP_PASS=
#MAIL_SENDMAIL_PATH=/usr/sbin/sendmail
#MAIL_FROM_ADDRESS=no-reply@example.com
#MAIL_FROM_NAME=Example
#MAIL_CONTACT_EMAIL=info@example.com

# -----------------------------------------------------------------------------
# SMS delivery (46elks API used by member registration)
# -----------------------------------------------------------------------------
# Master on/off switch. Defaults to false — explicitly set to true only where
# you actually want real texts sent (typically production only).
SMS_ENABLED=false

# Basic-auth credentials for https://api.46elks.com/a1/sms. Leave empty in dev.
SMS_API_USER=
SMS_API_PASS=

# "From" label shown on the recipient's phone. Max 11 chars, alphanumeric.
SMS_FROM=Medlemsreg

# -----------------------------------------------------------------------------
# WYSIWYG content sanitization
# -----------------------------------------------------------------------------
# When true (default), every save through the streams/chunks WYSIWYG field
# strips legacy CKEditor inline typography (font-size, font-family, color,
# <font>, MsoNormal, etc.) AND TinyMCE is configured client-side to refuse
# those properties and tags during editing. Set to false to disable both
# layers — useful while debugging unexpected content changes, or to keep
# rich-text bodies byte-for-byte unchanged across saves. The one-shot CLI
# cleanup script (system/cms/scripts/cleanup_wysiwyg_styles.php) ignores
# this flag — it always sanitizes whatever it's pointed at.
WYSIWYG_SANITIZE=true
