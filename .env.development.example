# =============================================================================
# Development `.env` template
# =============================================================================
#
# Copy to `.env` (gitignored) and edit for your local box:
#
#     cp .env.development.example .env
#
# Most keys below ship with sensible defaults for a local Herd/Valet/MAMP-style
# install against MySQL 8 or 5.7, so you can often run unmodified.
#
# See system/cms/bootstrap/env.php for loader semantics (real env vars always
# win over .env, so this is purely your local override surface).

# -----------------------------------------------------------------------------
# Application environment
# -----------------------------------------------------------------------------
# development / staging / production. In development: errors visible, file
# logging enabled, stricter debug behaviour.
PYRO_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=pyrocmspro2ng

DB_DRIVER=mysqli
DB_PREFIX=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# -----------------------------------------------------------------------------
# Debug flag
# -----------------------------------------------------------------------------
# Auto-derived from PYRO_ENV — ON in development, OFF elsewhere. Only set this
# explicitly if you want the non-default: e.g. APP_DEBUG=false locally when
# reproducing a prod-only symptom.
#APP_DEBUG=true

# -----------------------------------------------------------------------------
# Error log path
# -----------------------------------------------------------------------------
# Project-relative path. PyroCMS's own log ignores E_DEPRECATED; this file
# catches the fatals PHP's handler would otherwise drop on the floor.
APP_ERROR_LOG=system/cms/logs/php-fatals.log

# -----------------------------------------------------------------------------
# Encryption key
# -----------------------------------------------------------------------------
# Used by CI's Encryption + Session classes. Generate one with:
#   php -r "echo bin2hex(random_bytes(32));"
# Rotating invalidates existing encrypted cookies/sessions and any DB columns
# encrypted via $this->encrypt->encode() — users will need to log in again.
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Member-protected folder gate
# -----------------------------------------------------------------------------
# Comma-separated folder names whose files require an authenticated member.
# Must match File Manager folder names exactly (case-sensitive).
PROTECTED_FOLDERS=safe,member,medlem_seminbockar,medlem_video,medlem_dokument,medlem_dokument_2022,medlem_bilder,medlem_2019,medlem_2023,medlem_2024,medlem_2025,medlem_2026

# -----------------------------------------------------------------------------
# SMS alerting recipients
# -----------------------------------------------------------------------------
# Comma-separated <name>:<phone> pairs.
# Example: SMS_REGISTERED=Alice:+46701234567,Bob:+46707654321
SMS_REGISTERED=
