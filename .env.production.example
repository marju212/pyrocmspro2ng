# =============================================================================
# Production `.env` template
# =============================================================================
#
# Copy to `.env` on the production host (NEVER commit):
#
#     cp .env.production.example .env
#     $EDITOR .env                          # fill in the secrets
#     chmod 640 .env                        # owner = deploy user
#     chown deploy:www-data .env            # group = php-fpm user
#
# Prefer real environment variables over an on-disk .env for the *secrets*
# (DB_PASS especially) — FPM `env[DB_PASS]`, nginx `fastcgi_param`, Apache
# `SetEnv`, or `docker --env`. Real env vars win over .env values, so you can
# keep non-secret knobs in this file and pull secrets from the real env.
#
# See system/cms/bootstrap/env.php for loader semantics.

# -----------------------------------------------------------------------------
# Application environment
# -----------------------------------------------------------------------------
# MUST be 'production' on a real production host — drives the DB config group
# AND the APP_DEBUG default (production → debug OFF).
PYRO_ENV=production

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Replace CHANGE_ME values before first deploy.
DB_HOST=localhost
DB_PORT=3306
DB_USER=CHANGE_ME
DB_PASS=CHANGE_ME
DB_NAME=CHANGE_ME

DB_DRIVER=mysqli
DB_PREFIX=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# -----------------------------------------------------------------------------
# Debug flag
# -----------------------------------------------------------------------------
# Auto-OFF because PYRO_ENV=production. Leave commented in steady state.
# Flip temporarily when investigating a prod-only issue:
#   APP_DEBUG=true
# then reload FPM, reproduce, and immediately remove the line. Never leave
# debug on in prod for more than a diagnostic session — it leaks stack traces
# and config details into the response body.
#APP_DEBUG=false

# -----------------------------------------------------------------------------
# Error log path
# -----------------------------------------------------------------------------
# Point at a path your FPM user can write to. Absolute paths recommended in
# prod so you don't depend on the cwd. Make sure logrotate knows about this
# path if you don't want it growing forever.
APP_ERROR_LOG=/var/log/pyrocms/php-errors.log

# -----------------------------------------------------------------------------
# Encryption key
# -----------------------------------------------------------------------------
# MUST be set in prod. Used by CI's Encryption + Session classes. Generate with:
#   php -r "echo bin2hex(random_bytes(32));"
# Treat this like a database password — never commit, rotate on suspected leak.
# Rotating invalidates existing encrypted cookies/sessions and any DB columns
# encrypted via $this->encrypt->encode() — users will need to log in again.
ENCRYPTION_KEY=CHANGE_ME

# -----------------------------------------------------------------------------
# Member-protected folder gate
# -----------------------------------------------------------------------------
# Comma-separated folder names whose files require an authenticated member.
# Must match File Manager folder names exactly (case-sensitive). A missing or
# empty value falls back to the full known list in system/cms/config/config.php
# (fail-closed) — but set it explicitly in prod so you're not trusting the
# fallback to stay up-to-date.
PROTECTED_FOLDERS=safe,member,medlem_seminbockar,medlem_video,medlem_dokument,medlem_dokument_2022,medlem_bilder,medlem_2019,medlem_2023,medlem_2024,medlem_2025,medlem_2026

# -----------------------------------------------------------------------------
# SMS alerting recipients
# -----------------------------------------------------------------------------
# Comma-separated <name>:<phone> pairs. Leave empty to disable SMS alerts.
# Example: SMS_REGISTERED=Alice:+46701234567,Bob:+46707654321
SMS_REGISTERED=

# -----------------------------------------------------------------------------
# Multi-site default fallback
# -----------------------------------------------------------------------------
# core_sites.ref used when the incoming hostname matches no configured site
# or alias. Must be a ref that exists in core_sites. Empty = keep the legacy
# hardcoded 'default' stub (likely broken on multi-site installs).
DEFAULT_SITE=bockavel

# -----------------------------------------------------------------------------
# Mail delivery
# -----------------------------------------------------------------------------
# Master on/off. Leave true in prod; flip false only during controlled
# downtime or when bringing up a replacement SMTP provider.
MAIL_ENABLED=true

# These override the corresponding rows in admin → Settings → Email. Prefer
# real environment variables for secrets (MAIL_SMTP_PASS) over on-disk .env.
#MAIL_PROTOCOL=smtp
#MAIL_SMTP_HOST=
#MAIL_SMTP_PORT=587
#MAIL_SMTP_USER=
#MAIL_SMTP_PASS=CHANGE_ME
# Encryption mode for the SMTP submission. Defaults to 'tls' (STARTTLS) when
# unset — correct for ports 25 / 587 / 2525 / 8025. Use 'ssl' for implicit-TLS
# ports (465 / 8465 / 443). Production should never run with this empty.
#MAIL_SMTP_CRYPTO=tls
# SMTP connection timeout in seconds. Defaults to 15 when unset.
#MAIL_SMTP_TIMEOUT=15
#MAIL_SENDMAIL_PATH=/usr/sbin/sendmail
#MAIL_FROM_ADDRESS=no-reply@example.com
#MAIL_FROM_NAME=Example
#MAIL_CONTACT_EMAIL=info@example.com

# -----------------------------------------------------------------------------
# SMS delivery (46elks API used by member registration)
# -----------------------------------------------------------------------------
# Master on/off. Set true in prod only after SMS_API_USER/PASS are populated.
SMS_ENABLED=true

# Basic-auth credentials for https://api.46elks.com/a1/sms. Treat like a DB
# password: never commit, rotate on suspected leak.
SMS_API_USER=CHANGE_ME
SMS_API_PASS=CHANGE_ME

# "From" label shown on recipient's phone. Max 11 chars, alphanumeric.
SMS_FROM=Medlemsreg

# -----------------------------------------------------------------------------
# WYSIWYG content sanitization
# -----------------------------------------------------------------------------
# When true (default), every save through the streams/chunks WYSIWYG field
# strips legacy CKEditor inline typography (font-size, font-family, color,
# <font>, MsoNormal, etc.) AND TinyMCE is configured client-side to refuse
# those properties and tags during editing. Set to false to disable both
# layers — useful while debugging unexpected content changes, or to keep
# rich-text bodies byte-for-byte unchanged across saves. The one-shot CLI
# cleanup script (system/cms/scripts/cleanup_wysiwyg_styles.php) ignores
# this flag — it always sanitizes whatever it's pointed at.
WYSIWYG_SANITIZE=true
