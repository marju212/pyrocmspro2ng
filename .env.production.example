# =============================================================================
# Production `.env` template
# =============================================================================
#
# Copy to `.env` on the production host (NEVER commit):
#
#     cp .env.production.example .env
#     $EDITOR .env                          # fill in the secrets
#     chmod 640 .env                        # owner = deploy user
#     chown deploy:www-data .env            # group = php-fpm user
#
# Prefer real environment variables over an on-disk .env for the *secrets*
# (DB_PASS especially) — FPM `env[DB_PASS]`, nginx `fastcgi_param`, Apache
# `SetEnv`, or `docker --env`. Real env vars win over .env values, so you can
# keep non-secret knobs in this file and pull secrets from the real env.
#
# See system/cms/bootstrap/env.php for loader semantics.

# -----------------------------------------------------------------------------
# Application environment
# -----------------------------------------------------------------------------
# MUST be 'production' on a real production host — drives the DB config group
# AND the APP_DEBUG default (production → debug OFF).
PYRO_ENV=production

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Replace CHANGE_ME values before first deploy.
DB_HOST=localhost
DB_PORT=3306
DB_USER=CHANGE_ME
DB_PASS=CHANGE_ME
DB_NAME=CHANGE_ME

DB_DRIVER=mysqli
DB_PREFIX=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# -----------------------------------------------------------------------------
# Debug flag
# -----------------------------------------------------------------------------
# Auto-OFF because PYRO_ENV=production. Leave commented in steady state.
# Flip temporarily when investigating a prod-only issue:
#   APP_DEBUG=true
# then reload FPM, reproduce, and immediately remove the line. Never leave
# debug on in prod for more than a diagnostic session — it leaks stack traces
# and config details into the response body.
#APP_DEBUG=false

# -----------------------------------------------------------------------------
# Error log path
# -----------------------------------------------------------------------------
# Point at a path your FPM user can write to. Absolute paths recommended in
# prod so you don't depend on the cwd. Make sure logrotate knows about this
# path if you don't want it growing forever.
APP_ERROR_LOG=/var/log/pyrocms/php-errors.log
